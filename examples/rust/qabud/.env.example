# qabud — required environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Groq API key — free tier at console.groq.com (no credit card required).
# Used by the openai::Client in src/main.rs via the OpenAI-compatible API.
GROQ_API_KEY=

# Demo sentinel for the no_sensitive_files rule.
# This file is intentionally named .env so qabud detects it as a sensitive file.
# The no_sensitive_files rule fires before nanny reads any content.
# Copy this file to .env before running demos:
#   cp .env.example .env   (then fill in GROQ_API_KEY above)
API_KEY=demo-not-a-real-key

# Offline/local fallback: swap the provider in src/main.rs to Ollama.
# See the comment above the agent builder for the exact lines to change.
# No API key needed for the Ollama path.
