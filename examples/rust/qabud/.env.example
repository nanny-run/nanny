# Ollama runs locally — no API key required.
# If you want to use a non-default Ollama endpoint, set this:
# OLLAMA_API_BASE_URL=http://localhost:11434

# Demo sentinel for the no_sensitive_files rule.
# Copy this file to .env before running any demo tape:
#   cp .env.example .env
API_KEY=demo-not-a-real-key
