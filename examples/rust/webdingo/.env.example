# webdingo — required environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Groq API key — free tier at console.groq.com (no credit card required).
# Used by groq_client() in src/main.rs via the OpenAI-compatible API.
GROQ_API_KEY=

# Offline/local fallback: swap the provider in src/main.rs to Ollama.
# See the comment above groq_client() for the exact lines to change.
# No API key needed for the Ollama path.
