# dev_assist — required environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Groq API key — free tier at console.groq.com (no credit card required).
# Used by ChatGroq in agents/debug.py.
GROQ_API_KEY=

# Offline/local fallback: set MODEL = "llama3.2:3b" in config.py
# and swap ChatGroq for ChatOllama in agents/debug.py.
# No API key needed for the Ollama path.
