# metrics_crew — required environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Groq API key — free tier at console.groq.com (no credit card required).
# Used by CrewAI's LLM class when MODEL starts with "groq/".
GROQ_API_KEY=

# Offline/local fallback: set MODEL = "ollama/qwen2.5:7b" in config.py
# and run: ollama pull qwen2.5:7b && ollama serve
# No API key needed for the Ollama path.
