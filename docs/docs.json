{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Nanny Docs",
  "colors": {
    "primary": "#ff8800",
    "light": "#ff8800",
    "dark": "#a64f00"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "family": "Reddit Sans"
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/nanny-run/nanny"
      }
    ]
  },
  "redirects": [
    { "source": "/quickstart", "destination": "/v0.1/quickstart" },
    { "source": "/v0.1/install", "destination": "/v0.1/install" },
    { "source": "/v0.1.3/:slug*", "destination": "/v0.1/:slug*" },
    { "source": "/v0.1.4/:slug*", "destination": "/v0.1/:slug*" },
    { "source": "/v0.1.5/:slug*", "destination": "/v0.1/:slug*" }
  ],
  "navigation": {
    "versions": [
      {
        "version": "v0.1.x",
        "tag": "Latest",
        "tabs": [
          {
            "tab": "Getting Started",
            "pages": [
              "v0.1/index",
              "v0.1/quickstart",
              "v0.1/install",
              {
                "group": "Concepts",
                "pages": [
                  "v0.1/concepts/how-it-works",
                  "v0.1/concepts/limits",
                  "v0.1/concepts/event-log"
                ]
              },
              {
                "group": "SDKs",
                "pages": ["v0.1/guides/rust-sdk", "v0.1/guides/python-sdk"]
              },
              {
                "group": "CLI",
                "pages": ["v0.1/init", "v0.1/run", "v0.1/uninstall"]
              },
              {
                "group": "Reference",
                "pages": ["v0.1/reference/nanny-toml", "v0.1/reference/events"]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/nanny-run/nanny",
      "x": "https://x.com/nannyrun_"
    }
  }
}
